# PostgreSQL 接続情報
# POSTGRES_USER と POSTGRES_PASSWORD は db コンテナと app コンテナの両方で使われる

POSTGRES_DB=working_time_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_password_here

# アプリの DATABASE_URL（db サービス名でコンテナ間通信）
DATABASE_URL=postgresql://postgres:strong_password_here@db:5432/working_time_manager

# リバースプロキシ経由でアクセスする場合の公開ドメイン（Server Actions の CSRF 対策）
# カンマ区切りで複数指定可能
ALLOWED_ORIGINS=your-domain.example.com
